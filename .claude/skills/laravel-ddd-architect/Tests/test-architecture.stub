<?php

declare(strict_types=1);

// =============================================================================
// OPTION A — Pest arch() DSL (use when pestphp/pest is installed)
// Run with: ./vendor/bin/pest --filter=arch
// =============================================================================

arch('domain has no framework imports')
    ->expect('App\Domain\{{BoundedContext}}')
    ->not->toUse(['Illuminate', 'Symfony', 'Eloquent', 'Carbon\Carbon']);

arch('application has no http or eloquent imports')
    ->expect('App\Application\{{BoundedContext}}')
    ->not->toUse([
        'Illuminate\Http',
        'Illuminate\Database\Eloquent',
        'Illuminate\Support\Facades\Auth',
    ]);

arch('actions are readonly')
    ->expect('App\Application\{{BoundedContext}}')
    ->classes()
    ->toBeReadonly();

arch('controllers are invokable and thin')
    ->expect('App\Interface\Http\{{BoundedContext}}\Controller')
    ->toBeClasses();

arch('value objects are readonly')
    ->expect('App\Domain\{{BoundedContext}}\ValueObject')
    ->classes()
    ->toBeReadonly();

