use App\Interface\Http\{{BoundedContext}}\Policy\{{EntityName}}Policy;
use Illuminate\Support\Facades\Gate;
use Illuminate\Support\ServiceProvider;

final class {{BoundedContext}}ServiceProvider extends ServiceProvider
{
    /** @var array<class-string, class-string> */
    public array $bindings = [
        {{RepositoryName}}::class => Eloquent{{RepositoryName}}::class,
    ];

    public function boot(): void
    {
