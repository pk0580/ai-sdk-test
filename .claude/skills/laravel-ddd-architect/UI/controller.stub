<?php

declare(strict_types=1);

namespace App\Interface\Http\{{BoundedContext}}\Controller;

use App\Application\{{BoundedContext}}\UseCase\{{UseCaseName}}\{{DTO}};
use App\Application\{{BoundedContext}}\UseCase\{{UseCaseName}}\{{UseCaseName}}Action;
use App\Interface\Http\{{BoundedContext}}\Request\{{RequestName}};
use Illuminate\Http\JsonResponse;
use Symfony\Component\HttpFoundation\Response;

final class {{ControllerName}}
{
    public function __invoke(
        {{RequestName}} $request,
        {{UseCaseName}}Action $action,
    ): JsonResponse {
        $action->handle({{DTO}}::fromArray($request->validated()));

        return new JsonResponse(
            ['data' => ['status' => 'ok']],
            Response::HTTP_CREATED,
        );
    }
}
